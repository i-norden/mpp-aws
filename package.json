{
  "name": "mmp-aws",
  "version": "0.1.0",
  "description": "MPP-powered AWS compute marketplace",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db/migrate-cli.ts",
    "lint": "node scripts/lint.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.700.0",
    "@aws-sdk/client-ec2": "^3.700.0",
    "@aws-sdk/client-lambda": "^3.700.0",
    "@aws-sdk/client-pricing": "^3.700.0",
    "@hono/node-server": "^1.13.0",
    "@hono/prometheus": "^1.0.0",
    "hono": "^4.6.0",
    "ioredis": "^5.4.0",
    "kysely": "^0.27.0",
    "mppx": "^0.4.9",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "prom-client": "^15.1.0",
    "tweetnacl": "^1.0.3",
    "uuid": "^11.0.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

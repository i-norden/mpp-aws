# =============================================================================
# MMP-AWS Environment Configuration
# Copy to .env and fill in required values.
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=8080
HEALTH_PORT=8081

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://mmp:mmp@localhost:5432/mmp_aws?sslmode=disable

# ---------------------------------------------------------------------------
# MPP Configuration (REQUIRED)
# ---------------------------------------------------------------------------
# Facilitator URL for payment verification and settlement
FACILITATOR_URL=https://facilitator.example.com

# Network: "base-sepolia" (testnet) or "base" (mainnet)
NETWORK=base-sepolia

# Ethereum address that receives payments (REQUIRED)
PAY_TO_ADDRESS=

# USDC token contract address
# Base Sepolia default: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
# AWS_ENDPOINT_URL=http://localhost:4566  # LocalStack for dev

# ---------------------------------------------------------------------------
# Pricing (atomic USDC, 6 decimals)
# ---------------------------------------------------------------------------
# Base fee per invocation ($0.005)
BASE_FEE=5000

# Memory rate per 128MB ($0.001)
MEMORY_RATE_PER_128MB=1000

# Duration rate per 100ms ($0.0005)
DURATION_RATE_PER_100MS=500

# ---------------------------------------------------------------------------
# Access Control
# ---------------------------------------------------------------------------
# When true, only registered functions can be invoked
ENFORCE_WHITELIST=false

# Admin API key (leave empty to disable API key auth)
ADMIN_API_KEY=

# Comma-separated Ethereum addresses allowed admin access via EIP-191 signature
ADMIN_ADDRESSES=

# ---------------------------------------------------------------------------
# Registration
# ---------------------------------------------------------------------------
# Registration fee in atomic USDC ($1.00)
REGISTRATION_FEE=1000000

# Allow anyone to register functions via POST /register (with payment)
ALLOW_OPEN_REGISTER=false

# ---------------------------------------------------------------------------
# Refund System
# ---------------------------------------------------------------------------
REFUND_ENABLED=false

# Address that sends refunds (defaults to PAY_TO_ADDRESS)
REFUND_ADDRESS=

# Private key for signing refund transactions (REQUIRED when REFUND_ENABLED=true)
REFUND_PRIVATE_KEY=

# Base RPC URL for on-chain operations
RPC_URL=https://sepolia.base.org

# Fallback RPC URL
RPC_URL_FALLBACK=

# Fee percentage retained on refunds (0-100)
FEE_PERCENTAGE=10

# Minimum refund threshold in atomic USDC ($0.05)
MIN_REFUND_THRESHOLD=50000

# Estimated gas cost in atomic USDC ($0.01)
ESTIMATED_GAS_COST_USD=10000

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated allowed origins (use * for development only)
CORS_ALLOWED_ORIGINS=*

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
# Redis URL for distributed rate limiting (omit for in-memory)
REDIS_URL=redis://localhost:6379

# Global rate limit (requests per second)
GLOBAL_RATE_LIMIT=100

# Global burst size
GLOBAL_RATE_BURST=200

# Per-address rate limit (requests per second)
PER_ADDRESS_RATE_LIMIT=10

# Per-address burst size
PER_ADDRESS_RATE_BURST=20

# ---------------------------------------------------------------------------
# Lambda Invocation
# ---------------------------------------------------------------------------
# Endpoint verification timeout in seconds
ENDPOINT_VERIFY_TIMEOUT=5

# Lambda/HTTP invocation timeout in seconds
INVOKE_TIMEOUT=300

# ---------------------------------------------------------------------------
# Limits
# ---------------------------------------------------------------------------
# Maximum code size for sandbox execution (bytes)
MAX_CODE_SIZE_BYTES=1048576

# Maximum sandbox execution timeout (seconds)
MAX_EXECUTE_TIMEOUT=60

# Maximum URL length for HTTP endpoints
MAX_URL_LENGTH=2048

# ---------------------------------------------------------------------------
# Circuit Breaker
# ---------------------------------------------------------------------------
# Consecutive successes needed to close the circuit breaker
CB_SUCCESS_THRESHOLD=3

# ---------------------------------------------------------------------------
# Public URL
# ---------------------------------------------------------------------------
# Public-facing URL for the service (used in payment requirements)
PUBLIC_URL=

# ---------------------------------------------------------------------------
# Private Registry & Earnings
# ---------------------------------------------------------------------------
# Marketplace fee in basis points (100 bps = 1%)
MARKETPLACE_FEE_BPS=0

# Minimum earnings withdrawal in atomic USDC ($0.05)
MIN_EARNINGS_WITHDRAWAL=50000

# Maximum number of addresses in a function's access list
MAX_ACCESS_LIST_SIZE=1000

# ---------------------------------------------------------------------------
# EC2 Lease System
# ---------------------------------------------------------------------------
LEASE_ENABLED=false

# Comma-separated subnet IDs for EC2 instances
LEASE_SUBNET_IDS=

# Security group ID for EC2 instances
LEASE_SECURITY_GROUP_ID=

# VPC ID for per-lease security group creation
LEASE_VPC_ID=

# Maximum leases per user
LEASE_MAX_PER_USER=5

# Maximum provisioning retry attempts
LEASE_MAX_PROVISION_ATTEMPTS=3

# Price margin percentage on top of AWS cost
LEASE_MARGIN_PERCENT=20

# Pricing sync interval in hours
LEASE_PRICING_SYNC_HOURS=24

# Bandwidth check interval in seconds
LEASE_BANDWIDTH_CHECK_SECONDS=120

# Maximum globally active leases (0 = unlimited)
LEASE_MAX_GLOBAL_ACTIVE=0

# Provisioning timeout in minutes
LEASE_PROVISIONING_TIMEOUT_MINUTES=15

# Maximum age for cached AWS prices (hours)
LEASE_PRICE_MAX_AGE_HOURS=48

# Minutes before expiry to send warning webhook
LEASE_EXPIRY_WARNING_MINUTES=30

# Webhook URL for lease expiry warnings (leave empty to disable)
LEASE_EXPIRY_WEBHOOK_URL=

# Lease rate limiting
LEASE_RATE_LIMIT=20
LEASE_RATE_BURST=40

# Treasury address for lease collection
TREASURY_ADDRESS=

# Private key for collection wallet operations
COLLECTION_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Async Jobs
# ---------------------------------------------------------------------------
ASYNC_JOBS_ENABLED=false

# Maximum job TTL in hours
ASYNC_JOB_MAX_TTL_HOURS=24

# Worker polling interval in seconds
ASYNC_JOB_WORKER_INTERVAL=5

# Maximum concurrent job executions
ASYNC_JOB_MAX_CONCURRENT=10

# ---------------------------------------------------------------------------
# Pre-authorized Budgets
# ---------------------------------------------------------------------------
# Maximum budget TTL in hours (default: 7 days)
BUDGET_MAX_TTL_HOURS=168

# Maximum budget amount in atomic USDC ($100)
BUDGET_MAX_AMOUNT=100000000

# ---------------------------------------------------------------------------
# OFAC Compliance
# ---------------------------------------------------------------------------
# Comma-separated blocked addresses
OFAC_BLOCKED_ADDRESSES=

# Path to a file with blocked addresses (one per line)
OFAC_BLOCKED_ADDRESSES_FILE=

# ---------------------------------------------------------------------------
# Payer Allowlist
# ---------------------------------------------------------------------------
# Comma-separated addresses allowed to pay (empty = allow all)
ALLOWED_PAYER_ADDRESSES=

# ---------------------------------------------------------------------------
# Caching & Nonce TTL
# ---------------------------------------------------------------------------
# Function metadata cache TTL in seconds
FUNCTION_CACHE_TTL_SECONDS=60

# Payment nonce expiration in hours (1-24)
NONCE_EXPIRATION_HOURS=24

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
GRAFANA_URL=

# ---------------------------------------------------------------------------
# Endpoint Auth Encryption
# ---------------------------------------------------------------------------
# 64-character hex string (32 bytes) for encrypting stored endpoint auth
ENDPOINT_AUTH_KEY=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=info
# Set to "false" for human-readable logs in development
LOG_JSON=true
